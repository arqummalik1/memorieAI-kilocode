# ============================================
# MemorAI — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values.
# See SETUP_GUIDE.md for step-by-step instructions.
#
# All services below have FREE tiers — no credit card needed.
# ============================================


# ===== REQUIRED =====

# Supabase — Database, Auth, Storage
# Get yours at: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Google Gemini — AI chat, vision, embeddings
# Get yours at: https://aistudio.google.com/apikey
NEXT_PUBLIC_GEMINI_API_KEY=your-gemini-api-key

# Groq — Voice transcription (Whisper)
# Get yours at: https://console.groq.com/keys
NEXT_PUBLIC_GROQ_API_KEY=your-groq-api-key

# Google OAuth — Sign in with Google, Calendar, Gmail
# Get yours at: https://console.cloud.google.com/apis/credentials
# NOTE: The Client Secret goes in Supabase dashboard, NOT here.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com


# ===== OPTIONAL =====

# Resend — Email delivery (friend reminders, daily briefings)
# Get yours at: https://resend.com/api-keys
# Free tier: 100 emails/day, 3K/month
# Leave blank to disable email features.
NEXT_PUBLIC_RESEND_API_KEY=

# Web Push Notifications (VAPID keys)
# Generate with: npx web-push generate-vapid-keys
# Leave blank to disable push notifications.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
